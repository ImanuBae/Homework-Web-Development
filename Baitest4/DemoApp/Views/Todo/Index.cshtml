@model List<DemoApp.Models.TodoItem>
@{
    ViewData["Title"] = "Danh sách công việc";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BÀI TẬP VẬN DỤNG 2</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; font-size: 14px; background: #fff; }
        .page-header {
            background: linear-gradient(to bottom, #9b59b6, #7d3c98);
            color: white;
            text-align: center;
            padding: 10px 20px;
        }
        .page-header h2 { font-size: 16px; font-weight: bold; }
        .page-header p  { font-size: 13px; margin-top: 4px; }
        .content { padding: 20px 30px; }
        h3 { text-align: center; font-size: 18px; font-weight: bold; margin-bottom: 14px; }
        a.create-link { color: #0070c0; font-size: 13px; display: inline-block; margin-bottom: 10px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ccc; padding: 6px 10px; font-size: 13px; }
        th { background: #f5f5f5; text-align: left; }
        td.center { text-align: center; }
        td.actions a { color: #0070c0; font-size: 13px; }
        td.actions span { color: #999; margin: 0 2px; }
        a { text-decoration: none; }
        a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="page-header">
        <h2>BÀI TẬP VẬN DỤNG 2</h2>
        <p>Xây dựng ứng dụng TodoList với các chức năng: Xem danh sách, chi tiết, thêm, sửa, xoá</p>
    </div>
    <div class="content">
        <h3>DANH SÁCH CÔNG VIỆC</h3>
        <a class="create-link" href="/Todo/Create">Tạo mới công việc</a>
        <table>
            <thead>
                <tr>
                    <th>Mã công việc</th>
                    <th>Tên công việc</th>
                    <th>Trạng thái hoàn thành</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.TenCongViec</td>
                        <td class="center">
                            <input type="checkbox" disabled @(item.HoanThanh ? "checked" : "") />
                        </td>
                        <td class="actions">
                            <a href="/Todo/Edit/@item.Id">Sửa</a>
                            <span>|</span>
                            <a href="/Todo/Details/@item.Id">Chi tiết</a>
                            <span>|</span>
                            <form method="post" action="/Todo/Delete/@item.Id" style="display:inline"
                                  onsubmit="return confirm('Bạn có chắc muốn xóa?')">
                                <button type="submit" style="background:none;border:none;padding:0;color:#0070c0;cursor:pointer;font-size:13px;">Xoá</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>
