@model DemoApp.Models.TodoItem
@{
    ViewData["Title"] = "Chi tiết công việc";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BÀI TẬP VẬN DỤNG 2</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; font-size: 14px; background: #fff; }
        .page-header {
            background: linear-gradient(to bottom, #9b59b6, #7d3c98);
            color: white;
            text-align: center;
            padding: 10px 20px;
        }
        .page-header h2 { font-size: 16px; font-weight: bold; }
        .page-header p  { font-size: 13px; margin-top: 4px; }
        .content { padding: 20px 30px; max-width: 500px; }
        h3 { font-size: 20px; font-weight: normal; margin-bottom: 20px; }
        .field { margin-bottom: 12px; }
        .field label { font-size: 13px; color: #555; display: block; margin-bottom: 2px; }
        .field span { font-size: 14px; }
        .actions { margin-top: 16px; }
        .actions a { color: #0070c0; font-size: 13px; margin-right: 10px; text-decoration: none; }
        .actions a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="page-header">
        <h2>BÀI TẬP VẬN DỤNG 2</h2>
        <p>Xây dựng ứng dụng TodoList với các chức năng: Xem danh sách, chi tiết, thêm, sửa, xoá</p>
    </div>
    <div class="content">
        <h3>Chi tiết công việc</h3>
        <div class="field">
            <label>Mã công việc</label>
            <span>@Model.Id</span>
        </div>
        <div class="field">
            <label>Tên công việc</label>
            <span>@Model.TenCongViec</span>
        </div>
        <div class="field">
            <label>Trạng thái hoàn thành</label>
            <input type="checkbox" disabled @(Model.HoanThanh ? "checked" : "") />
        </div>
        <div class="actions">
            <a href="/Todo/Edit/@Model.Id">Sửa</a>
            <a href="/Todo/Index">Quay trở lại</a>
        </div>
    </div>
</body>
</html>
