@model TodoApp.Models.TodoItem
@{
    ViewData["Title"] = "Sửa công việc";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BÀI TẬP VẬN DỤNG 2</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: Arial, sans-serif; font-size: 14px; background: #fff; }
        .page-header {
            background: linear-gradient(to bottom, #9b59b6, #7d3c98);
            color: white;
            text-align: center;
            padding: 10px 20px;
        }
        .page-header h2 { font-size: 16px; font-weight: bold; }
        .page-header p  { font-size: 13px; margin-top: 4px; }
        .content { padding: 20px 30px; max-width: 500px; }
        h3 { font-size: 20px; font-weight: normal; margin-bottom: 20px; }
        .form-group { margin-bottom: 12px; }
        label { display: block; font-size: 13px; margin-bottom: 4px; }
        input[type="text"] {
            width: 200px; border: none; border-bottom: 1px solid #555;
            padding: 3px 0; font-size: 13px; outline: none; background: transparent;
        }
        input[readonly] { color: #555; }
        .checkbox-group { display: flex; align-items: center; gap: 6px; margin-bottom: 16px; }
        button[type="submit"] {
            background: #0070c0; color: white; border: none;
            padding: 5px 16px; font-size: 13px; cursor: pointer;
        }
        a.back-link { display: block; margin-top: 8px; color: #0070c0; font-size: 13px; text-decoration: none; }
        a.back-link:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="page-header">
        <h2>BÀI TẬP VẬN DỤNG 2</h2>
        <p>Xây dựng ứng dụng TodoList với các chức năng: Xem danh sách, chi tiết, thêm, sửa, xoá</p>
    </div>
    <div class="content">
        <h3>Sửa công việc</h3>
        <form method="post" action="/Todo/Edit">
            <input type="hidden" name="Id" value="@Model.Id" />
            <div class="form-group">
                <label>Mã công việc</label>
                <input type="text" value="@Model.Id" readonly />
            </div>
            <div class="form-group">
                <label>Tên công việc</label>
                <input type="text" name="TenCongViec" value="@Model.TenCongViec" />
            </div>
            <div class="checkbox-group">
                <input type="checkbox" name="HoanThanh" value="true" @(Model.HoanThanh ? "checked" : "") />
                <label style="margin:0">Trạng thái hoàn thành</label>
            </div>
            <button type="submit">Sửa</button>
        </form>
        <a class="back-link" href="/Todo/Index">Quay trở lại</a>
    </div>
</body>
</html>
