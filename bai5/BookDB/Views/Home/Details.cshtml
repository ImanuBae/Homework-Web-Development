@model BookDB.Models.Book

@{
    ViewData["Title"] = "Chi Tiết Sách";
}

<div class="container mt-5">
    <div class="row">

        <div class="col-md-4 text-center">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded shadow"
                     style="max-height:380px; object-fit:cover;" alt="@Model.Title" />
            }
            else
            {
                <div class="bg-light rounded d-flex align-items-center justify-content-center shadow"
                     style="height:300px; color:#aaa;">
                    Chưa có ảnh
                </div>
            }
        </div>

        <div class="col-md-8">
            <h3 class="fw-bold">@Model.Title</h3>
            <p class="mb-1"><strong>Tác giả:</strong> @Model.Author</p>
            <p class="mb-1"><strong>Thể loại:</strong> @Model.Category?.Name</p>
            <p class="mb-1"><strong>Ngày xuất bản:</strong> @Model.PublicationDate.ToString("dd/MM/yyyy")</p>
            <p class="mb-3"><strong>Số lượng còn:</strong> @Model.Quantity</p>

            <hr />

            <p class="mb-3">@Model.Description</p>

            <p class="fs-5 fw-bold text-danger mb-4">
                Giá bán: @Model.Price.ToString("N0") VND
            </p>

            <div class="d-flex gap-2">
                <a href="@Url.Action("Index", "Home")" class="btn btn-success px-4">Đặt mua</a>
                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">Quay lại</a>
            </div>
        </div>

    </div>
</div>
