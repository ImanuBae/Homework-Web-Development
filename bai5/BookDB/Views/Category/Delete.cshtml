@model BookDB.Models.Category

@{
    ViewData["Title"] = "Xóa Danh Mục";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="alert alert-danger">
                <h1>Xóa Danh Mục</h1>
                <p class="mt-3">Bạn có chắc chắn muốn xóa danh mục này?</p>
            </div>

            <div class="card mt-4">
                <div class="card-body">
                    <p><strong>Tên Danh Mục:</strong> @Model.Name</p>
                    <p><strong>Mô Tả:</strong> @Model.Description</p>
                    <p><strong>Số Sách:</strong> @Model.Books.Count</p>

                    @if (Model.Books.Count > 0)
                    {
                        <div class="alert alert-warning mt-3">
                            <strong>Lưu ý:</strong> Danh mục này có @Model.Books.Count sách. Xóa danh mục sẽ xóa tất cả các sách trong đó.
                        </div>
                    }

                    <hr />

                    <div class="mt-4">
                        <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" style="display: inline;">
                            <button type="submit" class="btn btn-danger">Xác Nhận Xóa</button>
                        </form>
                        <a href="@Url.Action("Index")" class="btn btn-secondary">Hủy</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
