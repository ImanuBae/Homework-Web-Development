@model IEnumerable<BookDB.Models.Category>

@{
    ViewData["Title"] = "Quản Lý Danh Mục";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Quản Lý Danh Mục</h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Thêm Danh Mục Mới
            </a>
        </div>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="card-text">@item.Description</p>
                        <p class="text-muted">
                            <small>Số sách: <span class="badge bg-info">@item.Books.Count</span></small>
                        </p>
                    </div>
                    <div class="card-footer bg-white border-top">
                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn btn-sm btn-warning">Sửa</a>
                        <a href="@Url.Action("Delete", new { id = item.Id })" class="btn btn-sm btn-danger">Xóa</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
