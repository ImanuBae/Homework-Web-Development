@model MyMvcApp.Models.SanPhamViewModel

@{
    ViewData["Title"] = "Bài tập 2";
}

<div class="text-center">
    <h1>Bài tập 2</h1>
    <div class="card mx-auto" style="max-width: 500px;">
        <img class="card-img-top" src="@Model.AnhMoTa" alt="@Model.TenSanPham" />
        <div class="card-body">
            <h2 class="card-title">@Model.TenSanPham</h2>
            <p class="card-text"><strong>Giá bán:</strong> @Model.GiaBan.ToString("N0") ₫</p>
        </div>
    </div>
</div>
